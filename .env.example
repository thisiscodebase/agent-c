# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Shared secret for Eve agent ↔ Nuxt internal API (memory, Slack link).
# Must match on both the Nuxt app and the Eve service in production.
INTERNAL_API_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional — canonical URL for SEO (Open Graph, canonical links)
# NUXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Database — required on Vercel (and any serverless host).
# Locally these can stay unset: NuxtHub falls back to a local SQLite file (.data/db).
# On Vercel that file cannot be created, so a hosted libSQL database is required.
# Provision via the Turso integration on the Vercel Marketplace (`vercel integration add turso`)
# and these are set automatically.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
