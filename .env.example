# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Shared secret for Eve agent ↔ Nuxt internal API (memory, Slack link).
# Must match on both the Nuxt app and the Eve service in production.
INTERNAL_API_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional — canonical URL for SEO (Open Graph, canonical links)
# NUXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Database — Supabase Postgres. DATABASE_URL should point at the Supavisor
# pooler in transaction mode (port 6543 on a hosted project) since Vercel
# Functions are serverless and would otherwise exhaust Postgres's direct
# connection limit. DIRECT_URL is the unpooled connection, used only for
# drizzle-kit migrations. Values below match `supabase start`'s local defaults.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Google Workspace OAuth (web only) — domain-restricted sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=
